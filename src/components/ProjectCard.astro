---
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  ref: string;
  featured: boolean;
  tags: string[];
}

const { title, description, image, tags, ref, featured } = Astro.props;
---

<article class="project-card">
  <a class="project-image" href={ref} target="_blank" rel="noopener noreferrer">
    <Image src={image} alt={title} loading="lazy"/>
  </a>

  <div class="project-content">
    <h2>{title}</h2>

    <p>
      {description}
    </p>

    <div class="project-tags">
      {featured && <div class="project-tag-featured">Featured</div>}
      {tags.map((tag) => <span>{tag}</span>)}
    </div>
  </div>
</article>

<style>
  .project-card {
    flex: 0 0 390px;
    scroll-snap-align: start;
    overflow: hidden;
    border-radius: var(--border-radius);
  }

  .project-image {
    display: flex;
    height: 230px;
    overflow: hidden;
    background: #111;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .project-image:hover img {
    transform: scale(1.1);
  }

  .project-content {
    background-color: var(--color-card);
    padding: 1.5rem;
  }

  .project-content h2 {
    color: var(--color-primary);
    margin: 0 0 0.7rem;
    font-size: 1.8rem;
  }

  .project-content p {
    margin: 0 0 1.3rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-tag-featured,
  .project-tags span {
    border-radius: var(--border-radius);
    padding: 0.35rem 0.75rem;
    font-size: 0.8rem;
    background: var(--color-surface-dark);
    color: var(--color-muted);
  }

  .project-tag-featured {
    color: var(--color-featured);
    border: 1px solid var(--color-featured);
  }

  @media (max-width: 480px) {
    .project-card {
      flex: 0 0 20rem;
    }

    .project-image {
      height: 160px;
    }

    .project-content {
      padding: 1.1rem;
    }

    .project-content h2 {
      margin: 0 0 0.5rem;
    }

    .project-content p {
      margin: 0 0 1rem;
    }

    .project-tag-featured,
    .project-tags span {
      padding: 0.3rem 0.6rem;
    }
  }
</style>
